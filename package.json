{
  "name": "brotherhood",
  "version": "1.0.0",
  "description": "MCP bridge between two Claude Code sessions on different computers, via a shared cloud relay (HTTP POST + SSE).",
  "main": "dist/mcp.js",
  "scripts": {
    "build:mcp": "esbuild src/mcp.ts --bundle --platform=node --outfile=dist/mcp.js --format=cjs",
    "build:relay": "esbuild src/relay.ts --bundle --platform=node --outfile=dist/relay.js --format=cjs",
    "build": "npm run build:mcp && npm run build:relay",
    "start:mcp": "node dist/mcp.js",
    "start:relay": "node dist/relay.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "sse",
    "bridge",
    "claude"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "eventsource": "^2.0.2",
    "express": "^4.19.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/eventsource": "^1.1.15",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.3",
    "esbuild": "^0.28.0",
    "typescript": "^5.8.3"
  }
}
